def render_pick_window(instances):
    """Sorted window picker via fzf with detail preview.
    Working CC windows first, then idle CC, then no CC.
    """
    r = subprocess.run(
        ["tmux", "list-windows", "-a", "-F",
         "#{session_name}:#{window_index}\t#{window_name}\t#{window_panes}"],
        capture_output=True, text=True, timeout=5
    )
    if r.returncode != 0:
        print("Could not list tmux windows.")
        return

    win_insts: dict = {}
    for inst in instances:
        wid = inst["pane"]["pane_id"].rsplit(".", 1)[0]
        win_insts.setdefault(wid, []).append(inst)

    working_wins, idle_cc_wins, no_cc_wins = [], [], []
    for line in r.stdout.strip().split("\n"):
        if not line:
            continue
        parts = line.split("\t")
        wid, wname, npanes = parts[0], parts[1], parts[2]
        insts = win_insts.get(wid, [])
        n_working = sum(1 for i in insts if is_working(i["state"], i["cpu"]))
        entry = (wid, wname, npanes, insts, n_working)
        if insts and n_working > 0:
            working_wins.append(entry)
        elif insts:
            idle_cc_wins.append(entry)
        else:
            no_cc_wins.append(entry)

    win_ids = []
    display_lines = []

    for group in [working_wins, idle_cc_wins, no_cc_wins]:
        for wid, wname, npanes, insts, n_working in group:
            if insts:
                n = len(insts)
                if n == 1:
                    info = _build_pane_info(insts[0])
                else:
                    idle = n - n_working
                    max_pct = 0
                    for i in insts:
                        u_info = i["usage_info"]
                        if u_info and u_info.get("usage"):
                            u = u_info["usage"]
                            total_in = (u.get("input_tokens", 0)
                                        + u.get("cache_read_input_tokens", 0)
                                        + u.get("cache_creation_input_tokens", 0))
                            m = u_info.get("model", "unknown")
                            mc = MODEL_CONTEXT.get(m, DEFAULT_CONTEXT)
                            max_pct = max(max_pct, total_in * 100 // mc)
                    info = f"[CC×{n}: {n_working}W {idle}I | ctx {max_pct}%]"
                label = (f"{GREEN}● WORKING{RESET}" if n_working
                         else f"{BLUE}○ IDLE   {RESET}")
                line = f"  {label}  {BOLD}[{wid}]{RESET} {wname:<20}  {DIM}{info}{RESET}"
            else:
                line = f"  {DIM}  ─         [{wid}] {wname}{RESET}"
            win_ids.append(wid)
            display_lines.append(line)

    if not shutil.which("fzf"):
        # No fzf: print sorted list and exit
        print(f"{BOLD}{CYAN}{'─' * 60}{RESET}")
        print(f"{BOLD}{CYAN}  Windows  (sorted by CC status){RESET}"
              f"  {DIM}install fzf for interactive mode{RESET}")
        print(f"{BOLD}{CYAN}{'─' * 60}{RESET}\n")
        for line in display_lines:
            print(line)
        print()
        return

    monitor_bin = shutil.which("claude-monitor") or f"{Path.home()}/.local/bin/claude-monitor"
    preview_cmd = f"{monitor_bin} --window-detail {{1}}"

    fzf_input = "\n".join(f"{win_ids[i]}\t{display_lines[i]}"
                          for i in range(len(win_ids)))
    result = subprocess.run(
        ["fzf", "--ansi", "--no-sort",
         "--prompt", "  window> ",
         "--with-nth", "2..", "--delimiter", "\t",
         "--height", "100%", "--reverse", "--border",
         "--preview", preview_cmd,
         "--preview-window", "right:55%:wrap"],
        input=fzf_input, capture_output=True, text=True
    )
    if result.returncode == 0:
        selected_wid = result.stdout.strip().split("\t")[0]
        subprocess.run(["tmux", "switch-client", "-t", selected_wid],
                       capture_output=True)


def render_tmux_status(instances):
    if not instances:
        print("")
        return

    working = sum(1 for i in instances if is_working(i["state"], i["cpu"]))
    idle = len(instances) - working

    parts = []
    if working > 0:
        parts.append(f"#[fg=green,bold]{working} working#[default]")
    if idle > 0:
        parts.append(f"{idle} idle")

    print(f"#[fg=magenta]CC#[default] {' '.join(parts)}")


def render_dashboard(instances):
    if not instances:
        print(f"{DIM}No Claude Code instances found in tmux.{RESET}")
        return

    now = datetime.now().strftime("%H:%M:%S")
    working_count = sum(1 for i in instances if is_working(i["state"], i["cpu"]))
    idle_count = len(instances) - working_count

    print(f"{BOLD}{CYAN}{'=' * 76}{RESET}")
    print(f"{BOLD}{CYAN}  tmux-claude{RESET}  {DIM}{len(instances)} instances"
          f" ({GREEN}{working_count} working{RESET}{DIM},"
          f" {BLUE}{idle_count} idle{RESET}{DIM})  {now}{RESET}")
    print(f"{BOLD}{CYAN}{'=' * 76}{RESET}")
    print()

    # Group instances by window, preserving encounter order
    window_groups: dict = {}
    win_order = []
    for inst in instances:
        win_id = inst["pane"]["pane_id"].rsplit(".", 1)[0]
        if win_id not in window_groups:
            window_groups[win_id] = []
            win_order.append(win_id)
        window_groups[win_id].append(inst)

    for g_idx, win_id in enumerate(win_order):
        group = window_groups[win_id]
        win_name = group[0]["pane"]["window_name"]
        n = len(group)
        w = sum(1 for i in group if is_working(i["state"], i["cpu"]))
        idle = n - w

        # Window group header
        if n > 1:
            header = f"▸ [{win_id}] {BOLD}{win_name}{RESET}"
            summary = (f"{DIM}{n} panes  "
                       f"{RESET}{GREEN}{w} working{RESET}{DIM},"
                       f" {RESET}{BLUE}{idle} idle{RESET}")
            fill = "─" * max(2, 50 - len(win_id) - len(win_name))
            print(f"  {header}  {DIM}{fill}{RESET}  {summary}")
        else:
            header = f"▸ [{win_id}] {BOLD}{win_name}{RESET}"
            fill = "─" * max(2, 62 - len(win_id) - len(win_name))
            print(f"  {header}  {DIM}{fill}{RESET}")

        for i, inst in enumerate(group):
            is_last = (i == n - 1)
            branch = "  └─" if is_last else "  ├─"
            cont   = "    " if is_last else "  │ "

            pane = inst["pane"]
            session = inst["session"]
            cpu = inst["cpu"]
            usage_info = inst["usage_info"]
            working = is_working(inst["state"], inst["cpu"])

            if working:
                status_icon = f"{BG_GREEN}{BOLD}{WHITE} WORKING {RESET}"
            else:
                status_icon = f"{BG_BLUE}{BOLD}{WHITE}  IDLE   {RESET}"

            duration = format_duration(session.get("startedAt"))
            cwd = shorten_path(session.get("cwd", "?"))

            print(f"{branch}  {status_icon}  {BOLD}{pane['pane_id']}{RESET}")
            print(f"{cont}   {DIM}Dir:{RESET} {CYAN}{cwd}{RESET}")
            print(f"{cont}   {DIM}PID:{RESET} {session.get('pid', '?')}"
                  f"  {DIM}Duration:{RESET} {YELLOW}{duration}{RESET}"
                  f"  {DIM}CPU:{RESET} {cpu:.1f}%"
                  f"  {DIM}Messages:{RESET} {inst['msg_count']}")

            if usage_info and usage_info.get("usage"):
                usage = usage_info["usage"]
                model = usage_info.get("model", "unknown")
                input_tokens = usage.get("input_tokens", 0)
                cache_read = usage.get("cache_read_input_tokens", 0)
                cache_create = usage.get("cache_creation_input_tokens", 0)
                output_tokens = usage.get("output_tokens", 0)
                total_input = input_tokens + cache_read + cache_create
                max_ctx = MODEL_CONTEXT.get(model, DEFAULT_CONTEXT)
                bar = context_bar(total_input, max_ctx)
                model_short = (model.replace("claude-", "")
                               .replace("-20250514", "")
                               .replace("-20250918", ""))
                print(f"{cont}   {DIM}Model:{RESET} {MAGENTA}{model_short}{RESET}"
                      f"  Context: {bar}"
                      f"  ({format_tokens(total_input)}/{format_tokens(max_ctx)})")
                print(f"{cont}   {DIM}Tokens{RESET}  in: {format_tokens(input_tokens)}"
                      f"  cached: {format_tokens(cache_read)}"
                      f"  out: {format_tokens(output_tokens)}")
            else:
                print(f"{cont}   {DIM}(no usage data yet){RESET}")

            if not is_last:
                print(f"  │")

        if g_idx < len(win_order) - 1:
            print()

    print()


def main():
    if "--version" in sys.argv or "-V" in sys.argv:
        print(f"tmux-claude {__version__}")
        return

    tmux_mode = "--tmux" in sys.argv
    watch_mode = "--watch" in sys.argv or "-w" in sys.argv
    notify_mode = "--notify" in sys.argv or "-n" in sys.argv
    update_panes_mode = "--update-panes" in sys.argv
    pick_window_mode = "--pick-window" in sys.argv

    if "--window-detail" in sys.argv:
        idx = sys.argv.index("--window-detail")
        win_id = sys.argv[idx + 1] if idx + 1 < len(sys.argv) else ""
        instances = collect_instances()
        render_window_detail(win_id, instances)
        return

    if pick_window_mode:
        instances = collect_instances()
        render_dashboard_fzf(instances)
        return

    if notify_mode:
        watch_mode = True

    while True:
        if watch_mode and not tmux_mode:
            os.system("clear")

        instances = collect_instances()

        if update_panes_mode:
            update_tmux_panes(instances)
            return

        if tmux_mode:
            render_tmux_status(instances)
            return

        if notify_mode:
            check_notifications(instances)

        render_dashboard(instances)

        if not watch_mode:
            break
        time.sleep(3)


if __name__ == "__main__":
    main()
